{
  "name": "taiyzun-site",
  "version": "1.0.0",
  "description": "Static site for taiyzun.com — helper scripts",
  "scripts": {
    "build": "npm run build:pages",
    "build:pages": "node scripts/build-cloudflare-pages.js",
    "build-odyssey-portrait-chunks": "node scripts/build-odyssey-portrait-chunks.js",
    "gallery:share-index": "node scripts/build-space-gallery-share-index.js",
    "gallery:chunks": "node scripts/build-space-gallery-chunks.js",
    "optimize-images": "node scripts/optimize-images.js",
    "optimize-odyssey-portraits": "node scripts/optimize-odyssey-portraits.js",
    "privacy-review": "node scripts/generate-private-image-review.js",
    "test:contact": "node scripts/test-contact-function.mjs",
    "test:seo-tracking": "node scripts/validate-seo-tracking-state.js",
    "test:safe": "npm run test:contact && npm run test:seo-tracking"
  },
  "dependencies": {
    "gsap": "^3.12.2",
    "pixi.js": "^8.19.0",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1079.0",
    "csso-cli": "^4.0.2",
    "lighthouse": "^12.8.2",
    "sharp": "^0.35.3",
    "terser": "^5.48.0"
  }
}
