{
  "name": "taiyzun-site",
  "version": "1.0.0",
  "description": "Static site for taiyzun.com — helper scripts",
  "scripts": {
    "build": "npm run build:pages",
    "build:pages": "node scripts/build-cloudflare-pages.js",
    "build-odyssey-portrait-chunks": "node scripts/build-odyssey-portrait-chunks.js",
    "gallery:share-index": "node scripts/build-space-gallery-share-index.js",
    "gallery:chunks": "node scripts/build-space-gallery-chunks.js",
    "optimize-images": "node scripts/optimize-images.js",
    "optimize-odyssey-portraits": "node scripts/optimize-odyssey-portraits.js",
    "privacy-review": "node scripts/generate-private-image-review.js",
    "test:contact": "node scripts/test-contact-function.mjs",
    "test:creation-share": "node scripts/test-creation-share-function.mjs",
    "test:seo-tracking": "node scripts/validate-seo-tracking-state.js",
    "test:safe": "npm run test:contact && npm run test:creation-share && npm run test:seo-tracking",
    "test:brand": "node scripts/verify-brand-assets.mjs",
    "test:dist": "node scripts/verify-dist.mjs",
    "test:ui": "playwright test",
    "test:a11y": "playwright test --grep @a11y",
    "test:ci": "npm run test:safe && npm run test:brand && npm run build && npm run test:dist",
    "smoke:production": "node scripts/smoke-production.mjs",
    "verify": "npm run test:ci"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "gsap": "^3.12.2",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1021.0",
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "csso-cli": "^4.0.2",
    "lighthouse": "^13.4.0",
    "sharp": "^0.34.5",
    "terser": "^5.47.1"
  }
}
